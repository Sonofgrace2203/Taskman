@page "/deleteacc"

@if (isLoading)
{
    <div style="display: flex;; width: 100%; height: 100vh; align-items: center; justify-content: center; font-size: 30px;">
        <LoadingCardMajor LoadingState="⏳ deleting user account..." />
    </div>
}
else
{
    <div style="display: flex;; width: 100%; height: 100vh; align-items: center; justify-content: center;">
        <NotLoginCard Title="Account deleted successful..." SubTitle="Click to login..." />
    </div>
}

@code {
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        await Task.Delay(4000);
        isLoading = false;
    }
}