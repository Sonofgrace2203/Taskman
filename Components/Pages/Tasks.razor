@code {
    private string taskTitle = "";
    private Priority taskPriority = Priority.Select_Priority;
    private string trimmedTaskTitle => taskTitle.Trim().ToUpper();

    public List<AppTask> tasks = new();

    // FIX: Using OnAfterRenderAsync ensures JS is active in the browser before attempting to read local storage
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            TaskService.OnChange += HandleStateChanged;
            await LoadTasksFromLocalStorage();
        }
    }

    private async Task AddTask()
    {
        if (string.IsNullOrEmpty(taskTitle) || taskPriority == Priority.Select_Priority) return;

        TaskService.Add(trimmedTaskTitle, taskPriority);
        taskTitle = "";
        taskPriority = Priority.Low;

        RefreshTasksList();
        await SaveTasksToLocalStorage();
    }

    private async Task ToggleTask(int id)
    {
        TaskService.ToggleCompleted(id);
        RefreshTasksList();
        await SaveTasksToLocalStorage(); // FIX: Added save fallback on checking/unchecking tasks
    }

    private async Task DeleteTask(int id)
    {
        TaskService.Delete(id);
        RefreshTasksList();
        await SaveTasksToLocalStorage(); // FIX: Added save fallback on deleting tasks
    }

    private void RefreshTasksList()
    {
        tasks = TaskService.GetAll();
        StateHasChanged();
    }

    // FIX: Serializes the list to a JSON string string representation so local storage accepts it properly
    private async Task SaveTasksToLocalStorage()
    {
        var jsonString = JsonSerializer.Serialize(tasks);
        await JS.InvokeVoidAsync("localStorage.setItem", "All_Tasks", jsonString);
    }

    // FIX: Retrieves JSON text string and correctly maps it back to C# structures safely
    private async Task LoadTasksFromLocalStorage()
    {
        try
        {
            var jsonString = await JS.InvokeAsync<string>("localStorage.getItem", "All_Tasks");
            if (!string.IsNullOrEmpty(jsonString))
            {
                var savedTasks = JsonSerializer.Deserialize<List<AppTask>>(jsonString);
                if (savedTasks != null)
                {
                    // If your central TaskService handles data state, seed it here or assign list directly:
                    tasks = savedTasks;
                    StateHasChanged();
                }
            }
            else
            {
                RefreshTasksList();
            }
        }
        catch
        {
            RefreshTasksList(); // Fallback safely if storage data gets corrupted
        }
    }

    private async void HandleStateChanged()
    {
        RefreshTasksList();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        TaskService.OnChange -= HandleStateChanged;
    }
} *@
